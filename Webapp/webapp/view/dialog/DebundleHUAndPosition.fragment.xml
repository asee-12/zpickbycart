<core:FragmentDefinition id="debundlehu-frg-def"
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<Dialog
	id="debundelHUAndPosition"
	title="{i18n>warning}"
	contentWidth="400px"
	state="{i18n>warning}"
	afterClose="closeDialog">
		<content>
			<Text id="debundelHUAndPosition-text" class="sapUiMediumMarginBottom sapUiSmallMarginBegin sapUiSmallMarginEnd" text="{parts:[{path: 'i18n>debundleHandlingUnitMessage'}, {path: 'local>/debundleHUId'}, {path: 'local>/debundlePosition'}], formatter: '.formatMessage'}"></Text>
		</content>
		<beginButton>
			<Button id="debundelHUAndPosition-ok-btn" text="{i18n>ok}" press="debundlePosition"></Button>
		</beginButton>
		<endButton>
			<Button id="debundelHUAndPosition-cancel-btn" text="{i18n>cancel}" press="closeDialog"></Button>
		</endButton>
	</Dialog>
</core:FragmentDefinition>