<core:FragmentDefinition id="sort-frag-def"
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<ViewSettingsDialog
		id="sortWarehouseOrder"
		confirm="handleConfirm">
		<sortItems>
			<ViewSettingsItem id="sortwho-item-who" text="{i18n>warehouseOrders}" key="EWMWarehouseOrder" />
			<ViewSettingsItem id="sortwho-item-huamount" text="{i18n>plannedHUs}" key="HuAmount" />
			<ViewSettingsItem id="sortwho-item-lsd" text="{i18n>latestStartTime}" key="WhseOrderLatestStartDateTime" selected="true" />
			<ViewSettingsItem id="sortwho-item-planneduration" text="{i18n>plannedDuration}" key="WarehouseOrderPlannedDuration"/>
			<ViewSettingsItem id="sortwho-item-queue" text="{i18n>Queue}" key="Queue" />
		</sortItems>
	</ViewSettingsDialog>
</core:FragmentDefinition>